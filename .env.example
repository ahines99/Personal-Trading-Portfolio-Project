# EODHD API key - https://eodhd.com/
EODHD_API_KEY=your_eodhd_api_key_here

# Finnhub API key - https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Tradier account identifiers for paper-trading config/bootstrap flows.
TRADIER_ACCOUNT_ID_SANDBOX=your_sandbox_account_id
TRADIER_ACCOUNT_ID_LIVE=your_live_account_id

# Optional paper-trading config overrides. Prefer config/paper_trading.yaml for
# committed non-secret defaults and use these only for local operator overrides.
# PAPER_TRADING_STAGE=2
# PAPER_TRADING_BROKER=tradier_sandbox
# PAPER_TRADING_CAPITAL_MODE=paper
# PAPER_TRADING_ACCOUNT_ID=your_sandbox_account_id
# PAPER_TRADING_RESULTS_DIR=results
# PAPER_TRADING_KILL_SWITCH_PATH=paper_trading/state/KILL_SWITCH

# Tradier API tokens belong in Windows Credential Manager via keyring.
# Emergency fallback only: the paper-trading secrets loader will read
# TRADIER_API_TOKEN, TRADIER_TOKEN_SANDBOX, TRADIER_API_TOKEN_SANDBOX,
# TRADIER_TOKEN_LIVE, or TRADIER_API_TOKEN_LIVE from the
# environment and emit a warning to stderr. Do not persist tokens in this file.

# No extra CPU-heavy dependency flags are required for paper-trading ops. Use the
# existing project environment; do not add local CUDA/torch/numba installs for
# the broker smoke, approval, or Phase A/Phase B operator commands.
